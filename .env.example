# ===== EduVerse Platform - Environment Configuration =====
# Copy this file to .env and configure your settings

# Django Core Settings
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.trycloudflare.com
SITE_BASE_URL=http://127.0.0.1:8000
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,https://localhost:8000,https://127.0.0.1:8000,https://*.trycloudflare.com

# WebRTC / Cloudflare Tunnel
WEBRTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
WEBRTC_TURN_URLS=turn:openrelay.metered.ca:80
WEBRTC_TURN_USERNAME=openrelayproject
WEBRTC_TURN_CREDENTIAL=openrelayproject
CLOUDFLARE_TUNNEL_URL=

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/eduverse_db

# Redis & Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Email Configuration
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@eduverse.com

# AWS S3 Storage
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_STORAGE_BUCKET_NAME=eduverse-media
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=your-bucket.s3.amazonaws.com
AWS_CLOUDFRONT_DISTRIBUTION_ID=your-distribution-id

# Use S3 for Media Files (True for production, False for local)
USE_S3=False

# Payment Gateways
# Stripe
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key
STRIPE_SECRET_KEY=sk_test_your_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Moyasar (Saudi Arabia)
MOYASAR_PUBLISHABLE_KEY=pk_test_your_moyasar_key
MOYASAR_API_KEY=sk_test_your_moyasar_secret

# Zoom Integration
ZOOM_API_KEY=your-zoom-api-key
ZOOM_API_SECRET=your-zoom-api-secret

# Google OAuth (django-allauth)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Facebook OAuth (django-allauth)
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Site Configuration
SITE_URL=http://localhost:8000
SITE_NAME=EduVerse

# Security (Production Only)
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_HSTS_SECONDS=0

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn

# Django Channels
CHANNEL_LAYERS_BACKEND=channels_redis.core.RedisChannelLayer
CHANNEL_LAYERS_CONFIG_HOSTS=redis://localhost:6379/1

# Cloudflare Tunnel (optional)
# If you use cloudflared, ضع هنا رابط النفق العام الخاص بك
CLOUDFLARE_TUNNEL_URL=https://your-tunnel-id.trycloudflare.com

# Logging Level
LOG_LEVEL=INFO
